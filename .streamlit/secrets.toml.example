# Streamlit Secrets 模板
# ============================================================
# 本地开发：
#   1. 复制此文件为 .streamlit/secrets.toml
#   2. 填入你的 OpenAI key
#   3. secrets.toml 不会被 git 提交（.gitignore 已排除）
#
# 云端部署（share.streamlit.io）：
#   不需要本地 secrets.toml，去 Streamlit Cloud 后台
#   App settings → Secrets 面板直接粘贴 toml 内容即可
# ============================================================

openai_api_key = "sk-proj-在这里填你的 key"

# 可选：如果用 OpenAI 中转代理，填 base_url；用官方 API 留空
openai_base_url = ""
